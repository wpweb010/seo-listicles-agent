# ---------------------------------------------------------------------------
# Copy this file to ".env" and paste your real keys.  NEVER commit .env.
# The script auto-loads .env (via python-dotenv) at startup.
# ---------------------------------------------------------------------------

# === FREE mode (mode = "free") — RECOMMENDED ===============================
# Serper.dev — Google SERP API with a 2,500-query free tier. No billing needed.
# Sign up at https://serper.dev/ and copy your API key.
SERPER_API_KEY=

# Open PageRank (free authority proxy, 0-100 score) — optional but recommended
# Get a key at https://www.domcop.com/openpagerank/
OPENPAGERANK_KEY=

# === FREE mode fallback (Google CSE) ========================================
# Used only if SERPER_API_KEY is empty. Requires billing enabled on
# Google Cloud Console.
# CSE setup:  https://programmablesearchengine.google.com  (create + copy cx)
# API key:    https://developers.google.com/custom-search/v1/overview
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# === SEMRUSH mode (mode = "semrush") =======================================
# Optional: Semrush API key for premium Authority Score + extra SERP coverage.
# Account -> Subscription Info -> API units.
SEMRUSH_API_KEY=
